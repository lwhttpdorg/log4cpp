@@ -0,0 +1,88 @@
+#!/usr/bin/env bash
+# This script runs inside the Docker container (as root).
+# It starts a minimal syslog receiver on /dev/log, runs the test binary,
+# then verifies the expected markers appear in the captured log.
+
+set -e
+
+LOGFILE="/tmp/syslog_capture.log"
+
+# Create a Unix datagram socket at /dev/log using python3,
+# capture received messages to LOGFILE.
+# Run in background; will be killed after test.
+python3 -c "
+import socket, os, sys, signal
+
+path = '/dev/log'
+if os.path.exists(path):
+    os.unlink(path)
+
+sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
+sock.bind(path)
+os.chmod(path, 0o666)
+sock.settimeout(5)
+
+with open('$LOGFILE', 'w') as f:
+    # Signal parent we are ready
+    print('SYSLOG_RECEIVER_READY', flush=True)
+    try:
+        while True:
+            data = sock.recv(8192)
+            line = data.decode('utf-8', errors='replace')
+            f.write(line + '\n')
+            f.flush()
+    except socket.timeout:
+        pass
+    except KeyboardInterrupt:
+        pass
+sock.close()
+" &
+
+RECEIVER_PID=$!
+
+# Wait for receiver to be ready
+sleep 1
+
+# Run the test binary
+./syslog_functional_test
+TEST_EXIT=$?
+
+# Give receiver time to flush
+sleep 1
+kill $RECEIVER_PID 2>/dev/null || true
+wait $RECEIVER_PID 2>/dev/null || true
+
+if [ $TEST_EXIT -ne 0 ]; then
+    echo "FAIL: test binary exited with code $TEST_EXIT"
+    exit 1
+fi
+
+# Verify markers in captured log
+echo "=== Captured syslog output ==="
+cat "$LOGFILE"
+echo "=== End captured output ==="
+
+PASS=0
+FAIL=0
+
+check_marker() {
+    if grep -q "$1" "$LOGFILE"; then
+        echo "PASS: found marker '$1'"
+        PASS=$((PASS + 1))
+    else
+        echo "FAIL: marker '$1' not found"
+        FAIL=$((FAIL + 1))
+    fi
+}
+
+check_marker "SYSLOG_TEST_MARKER_ABC123"
+check_marker "SYSLOG_TEST_MARKER_DEF456"
+check_marker "log4cpp_func_test"
+
+echo ""
+echo "Results: $PASS passed, $FAIL failed"
+
+if [ $FAIL -ne 0 ]; then
+    exit 1
+fi
+exit 0
