diff --git a/src/lib/appender/syslog_appender.cpp b/src/lib/appender/syslog_appender.cpp
new file mode 100644
index 0000000..ff3cab6
--- /dev/null
+++ b/src/lib/appender/syslog_appender.cpp
@@ -0,0 +1,111 @@
+#ifndef _WIN32
+
+#include <syslog.h>
+
+#include "appender/syslog_appender.hpp"
+
+namespace log4cpp::appender {
+
+    static int facility_from_string(const std::string &str) {
+        if (str == "LOG_USER") {
+            return LOG_USER;
+        }
+        if (str == "LOG_LOCAL0") {
+            return LOG_LOCAL0;
+        }
+        if (str == "LOG_LOCAL1") {
+            return LOG_LOCAL1;
+        }
+        if (str == "LOG_LOCAL2") {
+            return LOG_LOCAL2;
+        }
+        if (str == "LOG_LOCAL3") {
+            return LOG_LOCAL3;
+        }
+        if (str == "LOG_LOCAL4") {
+            return LOG_LOCAL4;
+        }
+        if (str == "LOG_LOCAL5") {
+            return LOG_LOCAL5;
+        }
+        if (str == "LOG_LOCAL6") {
+            return LOG_LOCAL6;
+        }
+        if (str == "LOG_LOCAL7") {
+            return LOG_LOCAL7;
+        }
+        if (str == "LOG_DAEMON") {
+            return LOG_DAEMON;
+        }
+        if (str == "LOG_KERN") {
+            return LOG_KERN;
+        }
+        if (str == "LOG_SYSLOG") {
+            return LOG_SYSLOG;
+        }
+        if (str == "LOG_AUTH") {
+            return LOG_AUTH;
+        }
+        throw std::invalid_argument("Invalid syslog facility: " + str);
+    }
+
+    static int option_from_string(const std::string &str) {
+        int option = 0;
+        // Simple parser for pipe-separated options like "LOG_PID|LOG_CONS"
+        std::string token;
+        for (size_t i = 0; i <= str.size(); ++i) {
+            if (i == str.size() || str[i] == '|') {
+                // Trim whitespace
+                size_t start = token.find_first_not_of(' ');
+                if (start == std::string::npos) {
+                    token.clear();
+                    continue;
+                }
+                size_t end = token.find_last_not_of(' ');
+                token = token.substr(start, end - start + 1);
+
+                if (token == "LOG_PID") {
+                    option |= LOG_PID;
+                }
+                else if (token == "LOG_CONS") {
+                    option |= LOG_CONS;
+                }
+                else if (token == "LOG_NDELAY") {
+                    option |= LOG_NDELAY;
+                }
+                else if (token == "LOG_ODELAY") {
+                    option |= LOG_ODELAY;
+                }
+                else if (token == "LOG_PERROR") {
+                    option |= LOG_PERROR;
+                }
+                else if (!token.empty()) {
+                    throw std::invalid_argument("Invalid syslog option: " + token);
+                }
+                token.clear();
+            }
+            else {
+                token += str[i];
+            }
+        }
+        return option;
+    }
+
+    syslog_appender::syslog_appender(const config::syslog_appender &cfg) : ident(cfg.ident) {
+        int facility = facility_from_string(cfg.facility);
+        int option = option_from_string(cfg.option);
+        openlog(ident.c_str(), option, facility);
+    }
+
+    void syslog_appender::log(const char *msg, size_t msg_len) {
+        // syslog expects a null-terminated string; msg from log_pattern is already null-terminated
+        syslog(LOG_INFO, "%.*s", static_cast<int>(msg_len), msg);
+    }
+
+    syslog_appender::~syslog_appender() {
+        closelog();
+    }
+
+} // namespace log4cpp::appender
+
+#endif
