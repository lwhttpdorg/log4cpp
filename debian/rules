#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# Cross-compilation: pick up toolchain file from environment
ifneq ($(CMAKE_TOOLCHAIN_FILE),)
  CROSS_CMAKE_FLAGS = -DCMAKE_TOOLCHAIN_FILE=$(CMAKE_TOOLCHAIN_FILE)
endif

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- $(CROSS_CMAKE_FLAGS)

override_dh_auto_build:
	dh_auto_build --parallel VERBOSE=1

override_dh_missing:
	dh_missing --fail-missing

override_dh_installdocs:
	# nothing
	:

override_dh_strip:
	dh_strip --no-ddebs

override_dh_auto_test:
	# Skip tests
	:
